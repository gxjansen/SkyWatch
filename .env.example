# Authentication is via AT Protocol OAuth — no credentials are stored here.
# After starting the server, connect once in your browser:
#   http://127.0.0.1:3000/login?handle=your.handle.bsky.social
# The session (tokens + DPoP key) is persisted in MongoDB and refreshed automatically.

# Optional: your handle, used as the default for /login and as the header fallback.
OWNER_HANDLE="your.handle.bsky.social"
# Optional: pin a specific account DID (single-user tool uses the stored session if omitted).
# OWNER_DID="did:plc:..."

# OAuth (optional overrides)
# OAUTH_SCOPE="atproto transition:generic"
# OAUTH_REDIRECT_BASE="http://127.0.0.1:3000"   # only change if tunneling the port

# MongoDB Connection
MONGODB_URI="mongodb://localhost:27017/bsky-follower-tracker"

# Server Configuration
PORT=3000
AUTO_IMPORT=true

# Refresh: accounts not fetched within this many days are re-fetched on a refresh.
# New accounts are always fetched; removed accounts are always pruned.
REFRESH_STALE_DAYS=7

# Rate Limit Configuration (0.0 to 1.0)
# Percentage of BlueSky's rate limits to use
RATE_LIMIT_AUTH=1.0      # Authentication calls
RATE_LIMIT_FOLLOWS=1.0   # Following/Profile operations
RATE_LIMIT_UNFOLLOW=1.0  # Unfollow operations
RATE_LIMIT_GENERAL=1.0   # Other API calls

# Development Settings
NODE_ENV=development
